{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/user.json",
  "title": "User",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    }
  },
  "required": ["id", "email"],
  "additionalProperties": false
}
