{
  "$id": "shipping.shipment-dispatched.v2",
  "type": "object",
  "required": [
    "shipmentId",
    "orderId",
    "carrier",
    "trackingCode",
    "origin",
    "destination",
    "items",
    "dispatchedAt"
  ],
  "properties": {
    "shipmentId": {
      "type": "string",
      "format": "uuid"
    },
    "orderId": {
      "type": "string"
    },
    "carrier": {
      "type": "string",
      "enum": ["correios", "fedex", "ups", "dhl", "loggi"]
    },
    "trackingCode": {
      "type": "string",
      "minLength": 6,
      "maxLength": 40
    },
    "origin": {
      "type": "object",
      "required": ["zipCode", "country"],
      "properties": {
        "zipCode": { "type": "string", "pattern": "^[0-9A-Z -]{3,12}$" },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 }
      }
    },
    "destination": {
      "type": "object",
      "required": ["zipCode", "country"],
      "properties": {
        "zipCode": { "type": "string", "pattern": "^[0-9A-Z -]{3,12}$" },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": ["sku", "quantity"],
        "properties": {
          "sku": { "type": "string", "minLength": 3 },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "weightKg": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "estimatedDeliveryAt": {
      "type": "string",
      "format": "date-time"
    },
    "dispatchedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
